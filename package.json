{
  "name": "welcome",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "check": "npm run lint && npm run typecheck",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "postinstall": "nuxt prepare",
    "prepare": "simple-git-hooks",
    "preview": "nuxt preview",
    "typecheck": "nuxt typecheck"
  },
  "dependencies": {
    "@nuxt/content": "^3.13.0",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/ui": "^4.6.1",
    "@vercel/analytics": "^2.0.1",
    "eslint": "^10.2.1",
    "nuxt": "^4.2.2",
    "typescript": "^6.0.3",
    "vue": "^3.5.26",
    "vue-router": "^5.0.6"
  },
  "overrides": {
    "archiver-utils": {
      "glob": "^13"
    }
  },
  "devDependencies": {
    "@iconify-json/heroicons": "^1.2.3",
    "lint-staged": "^16.4.0",
    "simple-git-hooks": "^2.13.1",
    "vue-tsc": "^3.2.7"
  },
  "lint-staged": {
    "*.{js,mjs,ts,vue}": "eslint --fix"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged",
    "pre-push": "npm run typecheck"
  }
}
